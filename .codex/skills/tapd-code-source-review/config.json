{
  "excluded_dirs": [
    ".git",
    "node_modules",
    "target",
    "build",
    "dist",
    ".idea",
    ".vscode",
    "__pycache__",
    ".pytest_cache"
  ],
  "text_extensions": [
    ".java",
    ".kt",
    ".xml",
    ".properties",
    ".yml",
    ".yaml",
    ".json",
    ".js",
    ".ts",
    ".tsx",
    ".py",
    ".go",
    ".php",
    ".sql",
    ".md",
    ".vue",
    ".conf",
    ".ini"
  ],
  "route_patterns": [
    "@(RequestMapping|GetMapping|PostMapping|PutMapping|DeleteMapping|PatchMapping)\\(([^)]*)\\)",
    "(?i)\\b(router|get|post|put|delete|patch)\\s*\\(\\s*['\"]([^'\"]+)['\"]"
  ],
  "table_patterns": [
    "(?i)\\bfrom\\s+([a-zA-Z0-9_.$]+)",
    "(?i)\\bjoin\\s+([a-zA-Z0-9_.$]+)",
    "(?i)\\bupdate\\s+([a-zA-Z0-9_.$]+)",
    "(?i)\\binto\\s+([a-zA-Z0-9_.$]+)",
    "@Table(?:Name)?\\(\\s*['\"]?([a-zA-Z0-9_.$]+)['\"]?"
  ],
  "outbound_patterns": [
    "(?i)\\b(feign|resttemplate|webclient|okhttp|httpclient|openfeign)\\b",
    "https?://[^\\s\"']+"
  ],
  "finding_rules": [
    {
      "priority": "P1",
      "title": "疑似敏感信息硬编码",
      "pattern": "(?i)(password|passwd|pwd|token|secret|access[_-]?key)\\s*[:=]\\s*['\"][^'\"]{6,}"
    },
    {
      "priority": "P2",
      "title": "存在 TODO/FIXME/临时代码",
      "pattern": "(?i)\\b(todo|fixme|临时|temporary|debug)\\b"
    },
    {
      "priority": "P1",
      "title": "疑似拼接 SQL",
      "pattern": "(?i)(select|update|delete|insert)\\s+.+\\+.+"
    },
    {
      "priority": "P2",
      "title": "疑似敏感日志输出",
      "pattern": "(?i)(log\\.|logger\\.|console\\.log).*(password|token|secret|authorization)"
    }
  ],
  "stopwords": [
    "测试", "用例", "步骤", "预期", "结果", "验证", "检查", "输入", "输出", "数据",
    "系统", "接口", "模块", "参数", "说明", "字段", "类型", "注释", "描述", "物理",
    "数据库", "相关", "符合", "需求", "阶段", "证据", "扫描", "提取", "通过", "测试用例",
    "given", "when", "then", "and", "but", "api", "http", "get", "post", "put", "delete"
  ]
}
